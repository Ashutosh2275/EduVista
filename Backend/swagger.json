{
  "openapi": "3.0.3",
  "info": {
    "title": "EduVista API",
    "description": "API documentation for the EduVista AI-Powered Educational Discovery Platform backend.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5000/api/v1",
      "description": "Local Development Server"
    }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "summary": "Register a new student user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "phone", "password"],
                "properties": {
                  "name": { "type": "string", "example": "Arjun Kumar" },
                  "email": { "type": "string", "format": "email", "example": "arjun@example.com" },
                  "phone": { "type": "string", "example": "9876543210" },
                  "password": { "type": "string", "example": "Password@123" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Student registered successfully." },
                    "data": {
                      "type": "object",
                      "properties": {
                        "user": { "type": "object" },
                        "accessToken": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Authenticate user credentials",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "example": "student@example.com" },
                  "password": { "type": "string", "example": "Password@123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful"
          }
        }
      }
    },
    "/colleges": {
      "get": {
        "summary": "Get all published colleges matching query parameters",
        "parameters": [
          { "name": "q", "in": "query", "schema": { "type": "string" } },
          { "name": "city", "in": "query", "schema": { "type": "string" } },
          { "name": "minFees", "in": "query", "schema": { "type": "integer" } },
          { "name": "maxFees", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Colleges list retrieved." }
        }
      }
    },
    "/wishlist": {
      "get": {
        "summary": "Get authenticated user's wishlist",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Wishlist details retrieved." }
        }
      }
    },
    "/compare": {
      "get": {
        "summary": "Get current compared colleges details (max 3)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Comparison details compiled." }
        }
      }
    },
    "/enquiries": {
      "post": {
        "summary": "Submit a public student enquiry",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "phone", "interestedCourse", "message"],
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "phone": { "type": "string" },
                  "interestedCourse": { "type": "string" },
                  "message": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Enquiry submitted successfully." }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
