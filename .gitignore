# ==========================================
# EduVista — Root Git Ignore
# ==========================================

# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
build/
*.tsbuildinfo

# Environment files (never commit secrets)
.env
.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Test coverage
coverage/
.nyc_output/

# Upload temp files (Backend)
Backend/uploads/*
!Backend/uploads/.gitkeep

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Editor / IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Cache
.cache/
.parcel-cache/
.turbo/
.eslintcache

# Vite
Frontend/.vite/
